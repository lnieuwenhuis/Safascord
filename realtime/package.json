{
  "name": "realtime",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:verify": "npm run typecheck && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/ws.js",
    "dev": "ts-node src/ws.ts"
  },
  "dependencies": {
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@vitest/coverage-v8": "^4.0.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "@types/ws": "^8.5.10",
    "vitest": "^4.0.14"
  }
}
