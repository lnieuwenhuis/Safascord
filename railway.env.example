# =========================
# Frontend Service
# =========================
VITE_API_BASE=https://api.cord.safasfly.dev/api
VITE_WS_BASE=wss://ws.cord.safasfly.dev/ws
VITE_SHOO_BASE_URL=https://shoo.dev

# =========================
# Backend Service
# =========================
PORT=4000
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
DATABASE_SSL=true
REDIS_URL=redis://default:<password>@<host>:<port>
JWT_SECRET=replace_with_long_random_secret
CORS_ORIGINS=https://cord.safasfly.dev
REALTIME_BASE_HTTP=http://realtime.railway.internal:4001
REALTIME_BASE_WS=wss://ws.cord.safasfly.dev/ws

# Shoo
SHOO_BASE_URL=https://shoo.dev
SHOO_ISSUER=https://shoo.dev
SHOO_ALLOWED_ORIGINS=https://cord.safasfly.dev
# Optional explicit client id (same format Shoo uses for browser-origin clients)
# SHOO_CLIENT_ID=origin:https://cord.safasfly.dev

# S3-Compatible Storage (Cloudflare R2, AWS S3, etc)
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>
S3_BUCKET_NAME=safascord-uploads
S3_PUBLIC_BASE_URL=https://cdn.safasfly.dev/safascord-uploads
S3_PUBLIC_URL=https://cdn.safasfly.dev
S3_FORCE_PATH_STYLE=false
S3_AUTO_INIT=false
S3_SET_PUBLIC_POLICY=false
S3_SET_LIFECYCLE=false
PROXY_UPLOADS=false
API_URL=https://api.cord.safasfly.dev
ENABLE_DEBUG_ROUTES=false

# =========================
# Realtime Service
# =========================
PORT=4001
REDIS_URL=redis://default:<password>@<host>:<port>
WS_ALLOWED_ORIGINS=https://cord.safasfly.dev
